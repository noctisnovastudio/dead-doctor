{
  "name": "dead-doctor",
  "version": "1.0.5",
  "description": "Static analysis CLI that finds dead code, unused exports, ghost pages, zombie dependencies, and leftover commented blocks in TypeScript and Next.js codebases.",
  "type": "module",
  "bin": {
    "dead-doctor": "./index.js"
  },
  "main": "./index.js",
  "files": [
    "index.js",
    "src/"
  ],
  "scripts": {
    "start": "node index.js"
  },
  "keywords": [
    "dead-code",
    "unused-exports",
    "unused-imports",
    "nextjs",
    "typescript",
    "static-analysis",
    "cli",
    "tree-shaking",
    "noctisnova"
  ],
  "author": "NoctisNova <hello@noctisnova.com> (https://noctisnova.com)",
  "homepage": "https://noctisnova.com",
  "repository": {
    "type": "git",
    "url": "https://github.com/noctisnova/dead-doctor"
  },
  "bugs": {
    "url": "https://github.com/noctisnova/dead-doctor/issues",
    "email": "hello@noctisnova.com"
  },
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "boxen": "^8.0.1",
    "chalk": "^5.4.1",
    "clipboardy": "^4.0.0",
    "ts-morph": "^24.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
